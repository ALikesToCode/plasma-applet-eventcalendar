#!/bin/bash

# User Variables
qtMinVer="5.12"
kfMinVer="5.68"
plasmaMinVer="5.18"
filenameTag="-plasma${plasmaMinVer}"
packageExt="plasmoid"

# Misc
startDir=$PWD
metadataFile="$PWD/package/metadata.json"

read_metadata() {
	local key="$1"
	python3 - "$metadataFile" "$key" <<'PY'
import json, sys
metadata_path = sys.argv[1]
key_path = sys.argv[2].split(".")
with open(metadata_path, "r", encoding="utf-8") as f:
	data = json.load(f)
for part in key_path:
	if not isinstance(data, dict):
		data = ""
		break
	data = data.get(part, "")
if data is None:
	data = ""
print(data)
PY
}

# Function Definitions

## Check Command Success
check_command_success() {
        if [ "$1" != "0" ]; then
                echoRed "[error] Failed executing: $2"
                exit 1
        fi
}

## Initialize Color Variables and Functions
initialize_colors() {
        # Color definitions
        TC_Red='\033[31m';
        TC_LightGray='\033[90m'; TC_LightGreen='\033[92m';
        TC_Reset='\033[0m';
        if [ ! -t 1 ]; then
                TC_Red='';
                TC_LightGray=''; TC_LightGreen='';
                TC_Reset='';
        fi

        # Color echo functions
        echoTC() {
                local text="$1"
                local textColor="$2"
                echo -e "${textColor}${text}${TC_Reset}"
        }
        echoGray() { echoTC "$1" "$TC_LightGray"; }
        echoRed() { echoTC "$1" "$TC_Red"; }
        echoGreen() { echoTC "$1" "$TC_LightGreen"; }
}

## Check QML Versions
check_qml_versions() {
        if [ -f checkimports.py ]; then
                python3 checkimports.py --qt="$qtMinVer" --kf="$kfMinVer" --plasma="$plasmaMinVer"
                check_command_success "$?" "Version check failed"
        fi
}

## Handle Translations
handle_translations() {
        if [ -d "package/translate" ]; then
                echoGray "[build] translate dir found, running merge."
                if ! (cd package/translate && bash ./merge); then
                        echoRed "[build] Translation extraction failed."
                        exit 1
                fi
                if ! (cd package/translate && bash ./build); then
                        echoRed "[build] Translation compilation failed."
                        exit 1
                fi
                if git rev-parse --is-inside-work-tree > /dev/null 2>&1 \
                        && ! git diff --quiet -- package/translate; then
                        echoRed "[build] Translation changes detected. Cancelling build."
                        git diff --stat -- package/translate
                        exit 1
                fi
        fi
}

## Convert metadata.desktop to metadata.json
convert_metadata() {
        if [ -f "$PWD/package/metadata.desktop" ] && command -v desktoptojson &> /dev/null ; then
                if desktoptojson --serviceType="plasma-applet.desktop" -i "$PWD/package/metadata.desktop" -o "$PWD/package/metadata.json"; then
                        sed -i '{s/ \{4\}/\t/g}' "$PWD/package/metadata.json"
                else
                        echoRed "[warn] desktoptojson conversion failed, keeping existing metadata.json"
                fi
        fi
}

## Package the plasmoid
package_plasmoid() {
        local packageNamespace
        packageNamespace=$(read_metadata "KPlugin.Id")
        local packageName="${packageNamespace##*.}" # Strip namespace (Eg: "org.kde.plasma.")
        local packageVersion
        packageVersion=$(read_metadata "KPlugin.Version")

        if [ -z "$packageNamespace" ] || [ -z "$packageVersion" ]; then
                echoRed "[error] Failed to read KPlugin.Id or KPlugin.Version from metadata.json"
                exit 1
        fi

        local filename="${packageName}-v${packageVersion}${filenameTag}.${packageExt}"
        rm -f -- "${packageName}"-v*."${packageExt}" # Cleanup
        echoGray "[${packageExt}] Zipping '${filename}'"
        if command -v zip > /dev/null 2>&1; then
                (cd package \
                        && zip -r "$filename" ./* \
                        && mv "$filename" "$startDir/$filename" \
                )
        else
                echoGray "[${packageExt}] 'zip' not found; using Python's zipfile module."
                (cd package \
                        && python3 -m zipfile -c "$filename" ./* \
                        && mv "$filename" "$startDir/$filename" \
                )
        fi
        echoGray "[${packageExt}] md5: $(md5sum "$filename" | awk '{ print $1 }')"
        echoGray "[${packageExt}] sha256: $(sha256sum "$filename" | awk '{ print $1 }')"
}

# Main Script Logic
initialize_colors
check_qml_versions
handle_translations
convert_metadata
package_plasmoid
echoGreen "[build] Packaging completed successfully."

# Return to start directory
cd "$startDir" || exit 1
